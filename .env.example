# 이 파일을 .env.local 로 복사한 뒤 값을 채우세요.
#   cp .env.example .env.local
#
# 값은 Supabase 대시보드 → Project Settings → API 에서 확인할 수 있습니다.
# .env.local 은 .gitignore 에 등록되어 있으므로 커밋되지 않습니다.

# 프로젝트 URL (예: https://abcdefghijk.supabase.co)
NEXT_PUBLIC_SUPABASE_URL=

# ⚠️ service_role 키 — 절대 공개하지 마세요.
#
# 이 키는 RLS를 우회하며 데이터베이스 전체에 대한 권한을 가집니다.
# 서버(Server Actions)에서만 사용되며 브라우저로 전송되지 않습니다
# (lib/supabase.ts 의 `import 'server-only'` 가 이를 강제합니다).
#
# NEXT_PUBLIC_ 접두사를 붙이지 마세요. 붙이면 클라이언트 번들에 포함되어
# 키가 그대로 노출됩니다.
SUPABASE_SERVICE_ROLE_KEY=
